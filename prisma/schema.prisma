generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserType {
  INDIVIDUAL
  CORPORATE
}

enum UserRole {
  CUSTOMER
  STAFF
  ADMIN
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketType {
  ONSITE
  REMOTE
  DEVICE
  GENERAL
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum DeviceStatus {
  RECEIVED
  INSPECTING
  WAITING_PARTS
  REPAIRED
  DELIVERED
  PRICE_APPROVAL
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String
  firstName       String
  lastName        String
  phone           String?
  userType        UserType  @default(INDIVIDUAL)
  role            UserRole  @default(CUSTOMER)
  isActive        Boolean   @default(true)
  emailVerified   DateTime?
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret  String?
  language        String    @default("tr")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Corporate fields
  companyName     String?
  taxOffice       String?
  taxNumber       String?
  nationalId      String?
  invoiceTitle    String?
  invoiceAddress  String?

  addresses       Address[]
  tickets         Ticket[]
  orders          Order[]
  invoices        Invoice[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  staffTickets    Ticket[]   @relation("AssignedTickets")
  ticketNotes     TicketNote[]
  messages        Message[]
  workSchedule    WorkSchedule?
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  address   String
  city      String
  district  String?
  zipCode   String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Ticket {
  id           String         @id @default(cuid())
  ticketNumber String         @unique
  userId       String
  user         User           @relation(fields: [userId], references: [id])
  assignedToId String?
  assignedTo   User?          @relation("AssignedTickets", fields: [assignedToId], references: [id])
  department   String
  service      String?
  priority     TicketPriority @default(MEDIUM)
  ticketType   TicketType     @default(GENERAL)
  status       TicketStatus   @default(OPEN)
  subject      String
  message      String
  attachments  String?

  // Onsite support
  address      String?
  deviceInfo   String?

  // Remote support
  remoteToolInfo String?

  resolvedAt   DateTime?
  slaDeadline  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  notes        TicketNote[]
  messages     Message[]
  survey       Survey?
}

model TicketNote {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  isInternal Boolean @default(true)
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  content   String
  createdAt DateTime @default(now())
}

model Survey {
  id              String   @id @default(cuid())
  ticketId        String   @unique
  ticket          Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  overallRating   Int?
  responseTime    Int?
  staffBehavior   Int?
  solutionQuality Int?
  comments        String?
  completedAt     DateTime?
  emailSentAt     DateTime?
  createdAt       DateTime @default(now())
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  parentId    String?
  parent      Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]
  blogPosts   BlogPost[]
  createdAt   DateTime  @default(now())
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  price       Float
  stock       Int      @default(0)
  imageUrl    String?
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  isActive    Boolean  @default(true)
  discount    Float?
  campaignInfo String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderItems  OrderItem[]
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  status      OrderStatus @default(PENDING)
  totalAmount Float
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  items       OrderItem[]
  invoice     Invoice?
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  orderId       String?  @unique
  order         Order?   @relation(fields: [orderId], references: [id])
  amount        Float
  taxAmount     Float    @default(0)
  totalAmount   Float
  issuedAt      DateTime @default(now())
  dueDate       DateTime?
  paidAt        DateTime?
  filePath      String?
  createdAt     DateTime @default(now())
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  imageUrl    String?
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  seoTitle    String?
  seoDescription String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String
  isActive    Boolean  @default(true)
  targetRole  String?
  publishedAt DateTime @default(now())
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String   @default("info")
  createdAt DateTime @default(now())
}

model CannedResponse {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model ServiceDevice {
  id           String       @id @default(cuid())
  customerId   String
  deviceName   String
  deviceModel  String?
  serialNumber String?
  status       DeviceStatus @default(RECEIVED)
  qrCode       String?
  notes        String?
  receivedAt   DateTime     @default(now())
  deliveredAt  DateTime?
  warrantyExpiry DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String   @default("text")
  language  String   @default("tr")
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  resource  String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}

model WorkSchedule {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startHour   Int      @default(9)
  endHour     Int      @default(18)
  workDays    String   @default("1,2,3,4,5")
  isRestricted Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Contract {
  id          String   @id @default(cuid())
  userId      String
  title       String
  type        String
  content     String
  signedAt    DateTime?
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model SliderContent {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String?
  linkUrl   String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  language  String   @default("tr")
  createdAt DateTime @default(now())
}
